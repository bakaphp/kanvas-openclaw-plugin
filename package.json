{
  "name": "@kanvas/openclaw-plugin",
  "version": "0.1.7",
  "description": "Connects agents to Kanvas — your company's nervous system for CRM, inventory, orders, and messaging.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bakaphp/kanvas-openclaw-plugin"
  },
  "keywords": [
    "openclaw",
    "kanvas",
    "crm",
    "plugin",
    "ai-agent"
  ],
  "type": "module",
  "openclaw": {
    "id": "kanvas",
    "extensions": [
      "./dist/index.js"
    ]
  },
  "files": [
    "dist/",
    "openclaw.plugin.json",
    "README.md"
  ],
  "scripts": {
    "prepublishOnly": "npm run build",
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "dev": "node --watch --loader ts-node/esm src/index.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.48"
  },
  "peerDependencies": {
    "openclaw": ">=2026.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "openclaw": "^2026.3.24",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  }
}
