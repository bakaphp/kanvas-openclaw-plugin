{
  "name": "kanvas-openclaw-plugin",
  "version": "0.1.0",
  "private": true,
  "description": "OpenClaw plugin for Kanvas CRM, inventory, and order management.",
  "type": "module",
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "dev": "node --watch --loader ts-node/esm src/index.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.48"
  },
  "peerDependencies": {
    "openclaw": ">=2026.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "openclaw": "^2026.3.24",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  }
}
